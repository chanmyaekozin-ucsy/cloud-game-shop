# Smile.one region slug (br, id, my, etc.)
SMILE_REGION=br

# Request timeout in seconds
SMILE_TIMEOUT=30

# false = off-screen headed browser (local macOS). Use true in Docker/Coolify.
SMILE_REFRESH_HEADLESS=false

# Seconds to wait during automated OAuth (default 120)
SMILE_LOGIN_WAIT_SECONDS=120

# Use installed Google Chrome for OAuth on macOS. Leave empty in Docker/Coolify (Chromium).
SMILE_BROWSER_CHANNEL=chrome

# Page used to verify session / read balance
SMILE_ORDER_URL=https://www.smile.one/br/customer/order

# Telegram bot (@cloud_gameshop_bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=
TELEGRAM_ADMIN_USERNAME=
# If Telegram API times out (common in MM), set a proxy e.g. socks5://127.0.0.1:1080
TELEGRAM_PROXY_URL=
TELEGRAM_CONNECT_TIMEOUT=60
TELEGRAM_READ_TIMEOUT=60

# KBZ Pay (reuse AirVPN session + proofs group)
KBZ_AUTO_VERIFY=true
KBZ_SESSION_PATH=.data/kbz_session.json
KBZ_MERCHANT_NAME=
KBZ_MERCHANT_PHONE=
KBZ_PAY_DISPLAY_NAME=
KBZ_PAY_PHONE=
KBZ_TX_EXAMPLE=82622
KBZ_SAMPLE_TX_IMAGE=data/sample_txid.jpg
PAYMENTS_PROOFS_GROUP_ID=
PAYMENT_TX_MAX_AGE_HOURS=2

# Balance monitor — posts + pins live status in proofs group (random 40–120s)
MONITOR_ENABLED=true
MONITOR_INTERVAL_MIN_SEC=40
MONITOR_INTERVAL_MAX_SEC=120
# KBZ balance probe interval (Smile.one still uses 40–120s above)
MONITOR_KBZ_INTERVAL_SEC=3600
# Optional: auto-refresh KBZ token on 401 from Frida/Reqable capture log
KBZ_FRIDA_LOG_PATH=

# Database
SQLITE_PATH=.data/cloud_gameshop.sqlite3

GEMINI_KEY=
GEMINI_MODEL=Gemini 3.1 Flash Lite
